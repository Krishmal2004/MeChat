generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql" 
}

model User {
  id               Int       @id @default(autoincrement())
  phone            String    @unique
  displayName      String?
  bio              String?
  avatarColor      String?
  avatarUrl        String?
  
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Message {
  id             Int      @id @default(autoincrement())
  content        String
  createdAt      DateTime @default(now())
  isRead         Boolean  @default(false)

  // Link to the sender
  senderPhone    String
  sender         User     @relation("SentMessages", fields: [senderPhone], references: [phone])

  // Link to the receiver
  receiverPhone  String
  receiver       User     @relation("ReceivedMessages", fields: [receiverPhone], references: [phone])
}