generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql" 
}

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  displayName String?
  bio         String?
  avatarColor String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}